<Window x:Class="FindEye.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:FindEye.App.Helpers"
        prism:ViewModelLocator.AutoWireViewModel="True"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="FindEye"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <md:DialogHost Identifier="RootDialog">
        <DockPanel>
            <Menu DockPanel.Dock="Top" FontSize="13">
                <MenuItem Header="{helpers:Translate Menu_File}">
                    <MenuItem Header="{helpers:Translate Menu_Exit}"
                              Command="{Binding ExitCommand}"
                              InputGestureText="Alt+F4" />
                </MenuItem>
                <MenuItem Header="{helpers:Translate Menu_Language}">
                    <MenuItem Header="{helpers:Translate Menu_English}"
                              Command="{Binding SwitchLanguageCommand}"
                              CommandParameter="en-US" />
                    <MenuItem Header="{helpers:Translate Menu_Chinese}"
                              Command="{Binding SwitchLanguageCommand}"
                              CommandParameter="zh-CN" />
                </MenuItem>
            </Menu>

            <ContentControl prism:RegionManager.RegionName="MainRegion" />
        </DockPanel>
    </md:DialogHost>
</Window>
