<UserControl x:Class="FindEye.App.Views.CompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:FindEye.App.Helpers"
             xmlns:converters="clr-namespace:FindEye.App.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <converters:DiffTypeToColorConverter x:Key="DiffTypeToColor" />
        <converters:DiffTypeToBackgroundConverter x:Key="DiffTypeToBg" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:DirIconConverter x:Key="DirIconConverter" />
        <converters:DiffTypeNameConverter x:Key="DiffTypeNameConverter" />

        <BooleanToVisibilityConverter x:Key="B2V" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ROW 0: Folder pickers -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{helpers:Translate FolderA}"
                           VerticalAlignment="Center" Margin="0,0,12,0"
                           FontSize="13" FontWeight="SemiBold" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding FolderAPath, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Select folder A..."
                         IsReadOnly="True"
                         Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" />
                <Button Grid.Row="0" Grid.Column="2"
                        Content="{helpers:Translate Browse}"
                        Command="{Binding BrowseFolderACommand}"
                        Margin="8,0,0,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{helpers:Translate FolderB}"
                           VerticalAlignment="Center" Margin="0,12,12,12"
                           FontSize="13" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding FolderBPath, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Select folder B..."
                         IsReadOnly="True"
                         Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                         Margin="0,12,0,12" />
                <Button Grid.Row="1" Grid.Column="2"
                        Content="{helpers:Translate Browse}"
                        Command="{Binding BrowseFolderBCommand}"
                        Margin="8,12,0,12"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="{helpers:Translate Cancel}"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,12,0" />
                    <Button Content="{helpers:Translate Compare}"
                            Command="{Binding CompareCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: Progress bar -->
        <Border Grid.Row="1"
                Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}"
                Padding="16,8" Margin="8,4,8,0"
                Background="{DynamicResource MaterialDesignCardBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0"
                             Value="{Binding ProgressPercent}"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Height="4" Margin="0,0,12,0"
                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressText}"
                           FontSize="11"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="400" />
            </Grid>
        </Border>

        <!-- ROW 2: Tree + Detail -->
        <Grid Grid.Row="2" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: TreeView -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <CheckBox DockPanel.Dock="Right"
                                  IsChecked="{Binding HideIdentical}"
                                  Content="Hide identical"
                                  FontSize="11"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="Results" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding TreeRoots}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              VirtualizingStackPanel.ScrollUnit="Pixel"
                              BorderThickness="0"
                              Background="Transparent"
                              SelectedItemChanged="OnTreeViewSelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <md:PackIcon Grid.Column="0"
                                                 Kind="{Binding IsDirectory, Converter={StaticResource DirIconConverter}}"
                                                 Width="16" Height="16" Margin="0,0,6,0"
                                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                 VerticalAlignment="Center" />

                                    <!-- Name -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Name}"
                                               Foreground="{Binding DiffType, Converter={StaticResource DiffTypeToColor}}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />

                                    <!-- Size -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               FontSize="10" Margin="12,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource MaterialDesignDivider}"
                          HorizontalAlignment="Stretch" />

            <!-- RIGHT: Detail panel -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <!-- Has selection -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedItem.Name}"
                                       FontSize="18" FontWeight="SemiBold"
                                       TextWrapping="WrapWithOverflow" Margin="0,0,0,16" />

                            <TextBlock Text="{helpers:Translate Detail_Path}"
                                       Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedItem.RelativePath}"
                                       Style="{StaticResource DetailValue}" />

                            <TextBlock Text="{helpers:Translate Detail_Size}"
                                       Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedItem.Size, Converter={StaticResource FileSizeConverter}}"
                                       Style="{StaticResource DetailValue}" />

                            <TextBlock Text="{helpers:Translate Detail_Modified}"
                                       Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedItem.LastWriteTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                       Style="{StaticResource DetailValue}" />

                            <TextBlock Text="{helpers:Translate Detail_Hash}"
                                       Style="{StaticResource DetailLabel}" />
                            <TextBlock Text="{Binding SelectedItem.Sha256Hash, TargetNullValue=N/A}"
                                       Style="{StaticResource DetailValue}"
                                       FontFamily="Consolas" FontSize="11"
                                       TextWrapping="WrapWithOverflow" />

                            <TextBlock Text="{helpers:Translate Detail_DiffType}"
                                       Style="{StaticResource DetailLabel}" />

                            <Border Margin="0,4,0,0" Padding="8,4" CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Background="{Binding SelectedItem.DiffType, Converter={StaticResource DiffTypeToBg}}">
                                <TextBlock Foreground="White" FontWeight="Bold" FontSize="12"
                                           Text="{Binding SelectedItem.DiffType, Converter={StaticResource DiffTypeNameConverter}}" />
                            </Border>

                            <TextBlock Text="{Binding SelectedItem.ErrorMessage}"
                                       Visibility="{Binding SelectedItem.ErrorMessage, Converter={StaticResource B2V}}"
                                       Foreground="Red" Margin="0,12,0,0"
                                       TextWrapping="Wrap" FontSize="11" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- No selection -->
                    <TextBlock Text="{helpers:Translate SelectFileHint}"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               FontSize="14" />
                </Grid>
            </Border>
        </Grid>

        <!-- ROW 3: Status bar -->
        <Border Grid.Row="3" Margin="12,4,12,12" Padding="12,8"
                Background="{DynamicResource MaterialDesignCardBackground}"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding SummaryText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="1"
                        Content="{helpers:Translate Extract}"
                        Command="{Binding ExtractCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        md:ButtonAssist.CornerRadius="4"
                        Padding="20,6" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
